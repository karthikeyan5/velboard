{
  "name": "velboard",
  "version": "1.0.0",
  "title": "Velboard",
  "description": "Real-time monitoring dashboard for OpenClaw agents",
  "panels": "panels",
  "data_sources": {
    "claude-usage": {
      "type": "file",
      "path": "~/.openclaw/workspace/claude-usage.json",
      "interval": "10s"
    },
    "sessions": {
      "type": "file",
      "path": "~/.openclaw/workspace/sessions-summary.json",
      "interval": "30s"
    }
  },
  "panelOrder": [
    "claude-usage",
    "updates",
    "cpu",
    "memory",
    "disk",
    "uptime",
    "processes",
    "openclaw-status",
    "sessions",
    "crons",
    "models"
  ],
  "landingPage": "pages/landing"
}